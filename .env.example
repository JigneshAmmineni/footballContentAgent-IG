# Google AI / Vertex AI
# For AI Studio (default): set GOOGLE_API_KEY, leave GOOGLE_GENAI_USE_VERTEXAI=FALSE
#GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# For Vertex AI (Agent Runtime): comment out GOOGLE_API_KEY, set the three vars below
# Requires: gcloud auth application-default login
#GOOGLE_GENAI_USE_VERTEXAI=TRUE
#GOOGLE_CLOUD_PROJECT=your_gcp_project_id
#GOOGLE_CLOUD_LOCATION=us-central1

# football-data.org (free tier — register at https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN=your_football_data_token_here

# NewsAPI.org (free tier — register at https://newsapi.org/register)
# 100 requests/day — used conservatively (5 queries/day max in this agent)
NEWS_API_KEY=your_newsapi_key_here

# FBref and Understat fetchers use headless Chrome (Selenium) — local dev only, not Agent Runtime.
# Set to true to enable them in dump_samples.py and NewsIngestAgent.
ENABLE_SLOW_FETCHERS=false
