# Google AI / Vertex AI
# For AI Studio (default): set GOOGLE_API_KEY, leave GOOGLE_GENAI_USE_VERTEXAI=FALSE
#GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# For Vertex AI (Agent Runtime): comment out GOOGLE_API_KEY, set the three vars below
# Requires: gcloud auth application-default login
#GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# OpenAI (image generation via gpt-image-2)
OPENAI_API_KEY=your_openai_api_key_here

# football-data.org (free tier — register at https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN=your_football_data_token_here

# NewsAPI.org (free tier — register at https://newsapi.org/register)
# 100 requests/day — used conservatively (5 queries/day max in this agent)
NEWS_API_KEY=your_newsapi_key_here

# GCS — bucket for storing generated post images (must have fine-grained ACL enabled)
# Objects are made publicly readable so Instagram can fetch them.
GCS_BUCKET_NAME=your-bucket-name

# Instagram Graph API
# System User access token with instagram_basic + instagram_content_publish permissions.
# Get the IG Business Account ID from: GET /me/accounts → /PAGE_ID?fields=instagram_business_account
INSTAGRAM_USER_ID=your_ig_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
